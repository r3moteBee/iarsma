// WIT contract for iarsma:jmap-client.
//
// Thin JMAP client wrapper. Per D-038 the component is parse-only â€” HTTP
// transport lives in the host. The component's job is "JMAP wire bytes â†’
// typed records" and "typed records â†’ JMAP wire bytes". Host code does the
// fetch and supplies the auth header.
//
// Capabilities:
//   - `session`: parse JMAP session resource (RFC 8620 Â§2).
//   - `mailbox`: parse `Mailbox/get` method response (RFC 8621 Â§2).
//
// Each interface owns its own `parse-error` / `parse-error-code` types
// because the relevant error cases differ per parser (e.g., session
// surfaces `no-mail-account` which is meaningless for mailbox parsing,
// and mailbox surfaces `method-error` which is meaningless for session
// parsing). The codegen-generated hosts unify them at the host
// invocation boundary into the workspace `IarsmaError` envelope (D-043);
// the component layer keeps shapes narrow and explicit.

package iarsma:jmap-client@0.2.0;

interface session {
    /// Narrow projection of a JMAP session resource (RFC 8620 Â§2). Matches
    /// the Session schema in the capability contract; new fields are added
    /// here only when a consumer needs them.
    record session {
        username: string,
        api-url: string,
        download-url: string,
        upload-url: string,
        event-source-url: string,
        state: string,
        /// `primaryAccounts["urn:ietf:params:jmap:mail"]` â€” extracted at
        /// parse time so consumers don't have to re-walk the JMAP shape.
        primary-account-id-mail: string,
    }

    /// Why a `parse-session` call rejected the input. The host should
    /// surface `code` + `message` to the caller; `message` includes the
    /// offending field path when applicable.
    record parse-error {
        code: parse-error-code,
        message: string,
    }

    enum parse-error-code {
        /// JSON was syntactically invalid.
        malformed-json,
        /// JSON parsed but a required field was absent.
        missing-field,
        /// JSON parsed but a field had the wrong shape (e.g., expected
        /// string, found number).
        wrong-type,
        /// `primaryAccounts` was present but didn't include
        /// `urn:ietf:params:jmap:mail`.
        no-mail-account,
    }

    /// Parse a JMAP session resource (the response body from
    /// `GET /.well-known/jmap`) into the narrowed `session` record. Pure;
    /// no I/O.
    parse-session: func(json: string) -> result<session, parse-error>;
}

interface mailbox {
    /// Per-mailbox rights (RFC 8621 Â§2.1.1). Bool fields mirror the JMAP
    /// `myRights` object. Surfaced so the UI can disable destructive
    /// actions (delete / rename / move) when the server says they're
    /// disallowed.
    record mailbox-rights {
        may-read-items: bool,
        may-add-items: bool,
        may-remove-items: bool,
        may-set-seen: bool,
        may-set-keywords: bool,
        may-create-child: bool,
        may-rename: bool,
        may-delete: bool,
        may-submit: bool,
    }

    /// Narrow projection of a JMAP `Mailbox` (RFC 8621 Â§2). Matches the
    /// Mailbox schema in the `mailbox.list` capability contract.
    record mailbox {
        id: string,
        name: string,
        /// `null` for top-level mailboxes; the id of the parent for nested.
        parent-id: option<string>,
        /// Special-use role: `inbox`, `sent`, `drafts`, `trash`, `junk`,
        /// `archive`, etc. Absent for ordinary user-created folders.
        role: option<string>,
        /// Display sort order â€” small integers; lower comes first.
        sort-order: u32,
        total-emails: u64,
        unread-emails: u64,
        total-threads: u64,
        unread-threads: u64,
        is-subscribed: bool,
        my-rights: mailbox-rights,
    }

    /// Why a `parse-mailbox-get-response` call rejected the input.
    record parse-error {
        code: parse-error-code,
        message: string,
    }

    enum parse-error-code {
        /// JSON was syntactically invalid.
        malformed-json,
        /// JSON parsed but a required field was absent (e.g.
        /// `methodResponses`, or a per-mailbox required field).
        missing-field,
        /// JSON parsed but a field had the wrong shape.
        wrong-type,
        /// The response carried no `Mailbox/get` method response, or the
        /// response array was empty. Likely a server-side misconfiguration
        /// or a wire-shape skew.
        empty-response,
        /// The server returned a `Mailbox/get` *error* method response
        /// (e.g. `accountNotFound`). Operator should check JMAP-side state.
        method-error,
    }

    /// Parse a JMAP request response body that includes a single
    /// `Mailbox/get` method response. Returns the `list` field â€” the
    /// flat array of `Mailbox` records the host renders into a tree by
    /// folding on `parent-id`. Pure; no I/O.
    ///
    /// The host is responsible for sending a `Mailbox/get` request that
    /// returns *all* mailboxes (no `ids` filter); pagination is not
    /// applicable to `Mailbox/get` per RFC 8621 Â§2.4.
    parse-mailbox-get-response: func(json: string) -> result<list<mailbox>, parse-error>;
}

interface email {
    /// JMAP email address (RFC 8621 Â§4.1.2.3 EmailAddress). `name` is
    /// the display name when present (e.g. "Alice <alice@x.example>"),
    /// `email` is the addr-spec.
    record email-address {
        name: option<string>,
        email: string,
    }

    /// JMAP `keyword` flag â€” RFC 8621 Â§4.1.1 reserves a few canonical
    /// keywords (`$seen`, `$flagged`, `$answered`, `$draft`, `$forwarded`,
    /// `$junk`, `$notjunk`, `$phishing`) but servers may surface custom
    /// keywords too. Modeled as a flat name â†’ bool list rather than a
    /// map because WIT records have fixed shapes; callers that want
    /// dictionary-style access can build one from the list.
    record keyword {
        name: string,
        value: bool,
    }

    /// Narrow projection of a JMAP `Email` (RFC 8621 Â§4) â€” only the
    /// metadata fields the thread-list view renders. Body parts (`bodyValues`,
    /// `htmlBody`, `textBody`, `attachments`) come from the future
    /// `thread.get` capability, which uses `Email/get` with a richer
    /// `properties` array.
    record email-summary {
        id: string,
        thread-id: string,
        // `%from` and `%to` use WIT's escape-keyword syntax so the
        // generated bindings call these `from` / `to` in TS â€” matching
        // both the JMAP wire shape and the typical React rendering
        // ergonomics. WIT reserves `from` as a keyword (per the
        // component-model spec); `to` isn't reserved but we escape it
        // for symmetry.
        %from: option<list<email-address>>,
        %to: option<list<email-address>>,
        subject: option<string>,
        /// Server-computed snippet for display in the inbox row.
        preview: option<string>,
        /// ISO 8601 / RFC 3339 timestamp the server stamped on receipt.
        /// Format is what the host receives over the wire â€” no parsing.
        received-at: string,
        keywords: list<keyword>,
        /// Total RFC 5322 message size in bytes.
        size: u64,
    }

    /// Result of an `Email/query` + chained `Email/get` round-trip. The
    /// host's request is composed of two methodCalls in one JMAP request
    /// (RFC 8620 Â§3.7): the first `Email/query` returns the matching ids,
    /// the second `Email/get` uses a back-reference (`#ids` â†’
    /// `Email/query.ids`) to fetch metadata in the same roundtrip.
    record email-query-result {
        emails: list<email-summary>,
        /// `position` echoed back from `Email/query`. Stable across
        /// `state`-token unchanged windows; pairs with the next
        /// `position + limit` to advance the page.
        position: u32,
        /// Total matching threads, when the host requested
        /// `calculateTotal: true`. Servers may legally omit it; the host
        /// surfaces the absence as `none`.
        total: option<u64>,
    }

    /// Why a `parse-email-query-response` call rejected the input.
    /// Mirrors the `mailbox` interface's parse-error shape but with one
    /// extra code (`partial-response`) for the chained-method-call case
    /// where one of the two methods returned data but the other didn't.
    record parse-error {
        code: parse-error-code,
        message: string,
    }

    enum parse-error-code {
        malformed-json,
        missing-field,
        wrong-type,
        empty-response,
        method-error,
        /// The response had `Email/query` data but no matching
        /// `Email/get` response (or vice versa). Indicates the host
        /// constructed the request envelope incorrectly or the server
        /// dropped one of the methodCalls.
        partial-response,
    }

    /// Parse a JMAP request response body that includes both an
    /// `Email/query` and a chained `Email/get` method response. Returns
    /// `email-query-result` with `emails` in `Email/get` order â€” which
    /// JMAP guarantees matches `Email/query.ids` order â€” and the
    /// `position` / `total` fields from `Email/query`. Pure; no I/O.
    parse-email-query-response: func(json: string) -> result<email-query-result, parse-error>;
}

world jmap-client {
    export session;
    export mailbox;
    export email;
}
