{
  "name": "@iarsma/mcp-server",
  "version": "0.0.0",
  "private": true,
  "description": "MCP server exposing capability-scoped tools for agents. Sibling to the shell.",
  "license": "MIT OR Apache-2.0",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -b",
    "start": "node dist/index.js",
    "test": "vitest run",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc -b --noEmit",
    "fmt": "prettier --write src",
    "fmt:check": "prettier --check src"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "eslint": "^9.13.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
