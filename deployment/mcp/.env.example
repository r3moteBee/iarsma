# Iarsma MCP server config. Copy to `.env` and fill in.
# See ./README.md for full guidance.

# ── Required ──────────────────────────────────────────────────────

# Stalwart base URL. The MCP server talks JMAP here, and validates
# agent bearer tokens by introspecting them at this issuer's OIDC
# introspection endpoint (D-057). Use the same URL you use to reach
# the webmail (typically https://your-mail-server-host).
IARSMA_JMAP_BASE_URL=https://sw-mail.example.test

# Default: leave both introspection env vars BLANK (D-058). The
# MCP server validates agent API keys by making a JMAP session call
# with the agent's own bearer — no operator credential required.
#
# Set IARSMA_INTROSPECTION_ADMIN_TOKEN only when your deployment
# still issues OAuth client_credentials tokens (D-057, legacy) and
# needs RFC 7662 introspection instead of x:ApiKey validation.
IARSMA_INTROSPECTION_ADMIN_TOKEN=

# ── Optional ──────────────────────────────────────────────────────

# Port + host the container listens on. Default 8765 / 0.0.0.0.
IARSMA_MCP_HTTP_PORT=8765
IARSMA_MCP_HTTP_HOST=0.0.0.0

# Discovery URN values surfaced back to MCP clients via the
# `urn:iarsma:agent-context` capability. Set when the URL clients
# should hit isn't the same as the container's internal port —
# e.g. when fronted by a reverse proxy at https://mcp.example.test.
IARSMA_WEBMAIL_MCP_URL=
IARSMA_AGENT_CONTEXT_ACTION_LOG_URL=
IARSMA_MEMORY_BACKEND_URL=

# OIDC issuer override. Defaults to IARSMA_JMAP_BASE_URL — usually
# you don't need to set this. Set it only when Stalwart serves OIDC
# from a different origin than JMAP (uncommon).
IARSMA_INTROSPECTION_ISSUER_URL=
