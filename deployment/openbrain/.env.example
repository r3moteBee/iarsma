# OpenBrain co-deployment env.
#
# Copy to `.env` and fill in `MCP_ACCESS_KEY` + (optionally) chat-API
# credentials. The defaults below give you a zero-API-key embeddings
# stack via bundled Ollama. Chat is BYO — set the CHAT_* vars to enable
# OB1's chat tools.
#
# See README.md for the OpenRouter (1536-dim) swap and other notes.

# ──────────────────────────────────────────────────────────────────────
# OB1 server version
# ──────────────────────────────────────────────────────────────────────

# Pinned upstream commit. Bump deliberately after reviewing the diff.
# Set to `main` to track upstream HEAD (faster updates, less reproducibility).
OB1_REF=9ff61353329ad511887b168030fa3d35f59f3dcc

# ──────────────────────────────────────────────────────────────────────
# Required: MCP access key
# ──────────────────────────────────────────────────────────────────────

# Bearer token MCP clients must present to call OB1. Pick a long random
# string (e.g. `openssl rand -hex 32`). Agents authenticate to OB1 with
# this directly — Iarsma's webmail does NOT proxy.
MCP_ACCESS_KEY=

# ──────────────────────────────────────────────────────────────────────
# Embeddings (default: bundled Ollama, no external API needed)
# ──────────────────────────────────────────────────────────────────────

EMBEDDING_API_BASE=http://ollama:11434/v1
EMBEDDING_API_KEY=ollama
EMBEDDING_MODEL=nomic-embed-text

# Embedding dimension. Must match the vector(N) in init/01-schema.sql:
#   nomic-embed-text (Ollama default)        →  768
#   openai/text-embedding-3-small (OpenRouter) → 1536
# If you change this, re-run docker compose down -v before bringing the
# stack back up so postgres re-runs the init scripts.

# ──────────────────────────────────────────────────────────────────────
# Chat (BYO — point at OpenRouter / Anthropic / Ollama / etc.)
# ──────────────────────────────────────────────────────────────────────

# Empty by default. OB1's chat tools error with a clear message until
# you fill these in. Example for OpenRouter:
#   CHAT_API_BASE=https://openrouter.ai/api/v1
#   CHAT_API_KEY=sk-or-...
#   CHAT_MODEL=openai/gpt-4o-mini
CHAT_API_BASE=
CHAT_API_KEY=
CHAT_MODEL=

# ──────────────────────────────────────────────────────────────────────
# Postgres
# ──────────────────────────────────────────────────────────────────────

POSTGRES_USER=openbrain
POSTGRES_PASSWORD=change-me
POSTGRES_DB=openbrain

# ──────────────────────────────────────────────────────────────────────
# Networking
# ──────────────────────────────────────────────────────────────────────

# Host port OB1 listens on. The webmail's `IARSMA_MEMORY_BACKEND_URL`
# should point at `http://<host>:<port>/mcp` (or a reverse-proxied URL).
OB1_HOST_PORT=8000

# ──────────────────────────────────────────────────────────────────────
# Citations
# ──────────────────────────────────────────────────────────────────────

# Base URL OB1 stamps onto thought citations. Set to whatever public URL
# you expose the thoughts at (e.g. your webmail's host).
OPEN_BRAIN_CITATION_BASE_URL=https://openbrain.local/thoughts
