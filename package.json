{
  "name": "iarsma",
  "version": "0.0.0",
  "private": true,
  "description": "Iarsma — JMAP-native webmail built for agent/human collaboration. Monorepo root.",
  "homepage": "https://iarsma.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/r3moteBee/iarsma.git"
  },
  "license": "MIT OR Apache-2.0",
  "author": "Brent Ellis <brent@r3motely.com>",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "bootstrap": "pnpm install && cargo build --workspace --quiet",
    "dev": "pnpm --filter '@iarsma/shell' dev",
    "build": "pnpm --filter '@iarsma/shell' build",
    "test": "pnpm -r run test",
    "lint": "pnpm -r run lint",
    "fmt": "pnpm -r run fmt && cargo fmt --all",
    "fmt:check": "pnpm -r run fmt:check && cargo fmt --all -- --check",
    "typecheck": "pnpm -r run typecheck",
    "wasm": "cargo build --workspace --target wasm32-wasip2 --release",
    "codegen": "pnpm --filter '@iarsma/codegen' run build",
    "clean": "pnpm -r exec rm -rf dist node_modules && cargo clean"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "typescript": "^5.6.3"
  }
}
