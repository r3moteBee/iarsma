{
  "name": "@iarsma/codegen",
  "version": "0.0.0",
  "private": true,
  "description": "Capability-contract codegen. Reads Zod schemas via introspection; emits React hooks, MCP tool registrations, JSON Schema, and OpenAPI docs from a single intermediate AST.",
  "license": "MIT OR Apache-2.0",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -b",
    "codegen": "tsx src/run.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc -b --noEmit",
    "fmt": "prettier --write src contracts",
    "fmt:check": "prettier --check src contracts"
  },
  "dependencies": {
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.23.5"
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "@typescript-eslint/parser": "^8.12.0",
    "@typescript-eslint/rule-tester": "^8.12.0",
    "@typescript-eslint/utils": "^8.12.0",
    "ajv": "^8.17.1",
    "eslint": "^9.13.0",
    "fast-check": "^3.23.1",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vitest": "^3.2.6"
  }
}
