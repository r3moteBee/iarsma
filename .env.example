# Iarsma — example environment. Copy to .env (gitignored) and fill in.
# Used by Justfile recipes that need server context.

# JMAP / Stalwart
JMAP_HOST=sw-mail.example.net
JMAP_USER=user@example.net
JMAP_PASSWORD=

# OAuth client (registered in Stalwart admin → Directory → OAuth Clients).
# `webmail` is the historical client_id from Phase -1 registration. Rename in
# Stalwart admin if you want this to match the project name.
OIDC_ISSUER=https://sw-mail.example.net
OIDC_CLIENT_ID=webmail
# OIDC_CLIENT_SECRET is consumed by the token-exchange sidecar only.
# It MUST NEVER appear in any client-side bundle.
OIDC_CLIENT_SECRET=

# Token-exchange sidecar
TOKEN_EXCHANGE_PORT=4000
# Bind address. Defaults to 127.0.0.1 (loopback) — the sidecar holds the
# client_secret and must sit behind a same-host reverse proxy. Set 0.0.0.0
# only when the proxy runs on another host and the network is trusted.
TOKEN_EXCHANGE_HOST=127.0.0.1
TOKEN_EXCHANGE_ALLOWED_REDIRECT_URIS=http://localhost:5173/auth/callback,http://localhost:1420/auth/callback,https://sw-mail.example.net/webmail/auth/callback

# MCP server
MCP_SERVER_PORT=4001

# Optional: Open Brain (memory backend Tier 2)
# Leave blank to use Tier-1 default (browser-side, structured-only).
MEMORY_BACKEND_TYPE=
MEMORY_BACKEND_URL=
